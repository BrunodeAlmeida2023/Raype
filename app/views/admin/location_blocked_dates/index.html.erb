<div class="admin-page">
  <div class="admin-page-header">
    <h1 class="admin-page-title"><i class="fas fa-map-marker-alt"></i> Bloqueios por Localização</h1>
    <%= link_to 'Novo Bloqueio de Localização', new_admin_location_blocked_date_path, class: 'admin-btn-danger' %>
  </div>

  <div class="admin-card">
    <div class="admin-card-body">
      <div class="admin-info-box" style="background: #fff3cd; border-left: 4px solid #ffc107; padding: 1rem; margin-bottom: 1.5rem;">
        <strong><i class="fas fa-info-circle"></i> Sobre Bloqueios de Localização:</strong>
        <p style="margin: 0.5rem 0 0 0; color: #856404;">
          Ao bloquear uma <strong>localização</strong>, todos os usuários serão impedidos de selecionar esta localização durante o período especificado.
          Use esta funcionalidade para aluguéis presenciais que ocupam um local físico específico.
        </p>
        <p style="margin: 0.5rem 0 0 0; color: #856404;">
          <i class="fas fa-exclamation-triangle"></i> <strong>Orçamentos pendentes</strong> que conflitam com o bloqueio serão <strong>cancelados automaticamente</strong>.
          O date picker dos usuários será ajustado para iniciar após o período bloqueado.
        </p>
      </div>

      <% if @location_blocked_dates.any? %>
        <table class="admin-table">
          <thead>
            <tr>
              <th>Localização</th>
              <th>Período</th>
              <th>Duração</th>
              <th>Motivo</th>
              <th>Bloqueado por</th>
              <th>Status</th>
              <th>Criado em</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% @location_blocked_dates.each do |blocked| %>
              <tr class="<%= 'admin-row-expired' if blocked.end_date < Date.today %>">
                <td>
                  <strong><%= blocked.location_label %></strong>
                </td>
                <td>
                  <%= blocked.start_date.strftime('%d/%m/%Y') %> - <%= blocked.end_date.strftime('%d/%m/%Y') %>
                </td>
                <td>
                  <%= blocked.duration_days %> dias
                </td>
                <td>
                  <%= blocked.reason || '-' %>
                </td>
                <td>
                  <%= blocked.admin_user&.email || 'Sistema' %>
                </td>
                <td>
                  <% if blocked.end_date < Date.today %>
                    <span class="admin-badge admin-badge-secondary">Expirado</span>
                  <% elsif blocked.start_date <= Date.today && blocked.end_date >= Date.today %>
                    <span class="admin-badge admin-badge-danger">Ativo</span>
                  <% else %>
                    <span class="admin-badge admin-badge-warning">Futuro</span>
                  <% end %>
                </td>
                <td>
                  <%= blocked.created_at.strftime('%d/%m/%Y %H:%M') %>
                </td>
                <td>
                  <%= button_to 'Remover', admin_location_blocked_date_path(blocked),
                      method: :delete,
                      data: { confirm: 'Tem certeza que deseja remover este bloqueio de localização?' },
                      class: 'admin-btn-sm admin-btn-danger' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="admin-empty-state">
          <i class="fas fa-info-circle"></i>
          Nenhuma localização bloqueada no momento.
        </p>
      <% end %>
    </div>
  </div>
</div>

