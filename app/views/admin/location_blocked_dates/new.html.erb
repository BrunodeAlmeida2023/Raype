<div class="admin-page">
  <div class="admin-page-header">
    <h1 class="admin-page-title"><i class="fas fa-map-marker-alt"></i> Novo Bloqueio de Localização</h1>
    <%= link_to 'Voltar', admin_location_blocked_dates_path, class: 'admin-btn-secondary' %>
  </div>
  <div class="admin-card">
    <div class="admin-card-body">
      <%= form_with model: @location_blocked_date, url: admin_location_blocked_dates_path, local: true, class: 'admin-form' do |f| %>
        <div class="admin-form-group">
          <%= f.label :outdoor_location, "Localização:", class: "admin-form-label" %>
          <%= f.select :outdoor_location, 
              Outdoor.outdoor_location_options.map { |label, value| [label, value] },
              { prompt: 'Selecione' },
              { class: "admin-form-input", required: true } %>
        </div>
        <div class="admin-form-grid">
          <div class="admin-form-group">
            <%= f.label :start_date, "Data Inicial:", class: "admin-form-label" %>
            <%= f.date_field :start_date, class: "admin-form-input", required: true, min: Date.today %>
          </div>
          <div class="admin-form-group">
            <%= f.label :end_date, "Data Final:", class: "admin-form-label" %>
            <%= f.date_field :end_date, class: "admin-form-input", required: true, min: Date.today %>
          </div>
        </div>
        <div class="admin-form-group">
          <%= f.label :reason, "Motivo:", class: "admin-form-label" %>
          <%= f.text_area :reason, class: "admin-form-input", rows: 3 %>
        </div>
        <div class="admin-form-actions">
          <%= f.submit "Bloquear Localização", class: "admin-btn-danger" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
