<div class="admin-page">
  <div class="admin-page-header">
    <h1 class="admin-page-title"><i class="fas fa-tags"></i> Gerenciar Promoções</h1>
    <%= link_to 'Nova Promoção', new_admin_promotion_path, class: 'admin-btn-success' %>
  </div>

  <div class="admin-card">
    <div class="admin-card-body">
      <div class="admin-info-box" style="background: #d4edda; border-left: 4px solid #28a745; padding: 1rem; margin-bottom: 1.5rem;">
        <strong><i class="fas fa-info-circle"></i> Sobre Promoções:</strong>
        <p style="margin: 0.5rem 0 0 0; color: #155724;">
          Configure preços promocionais para <strong>mensalidade</strong> ou <strong>instalação</strong> de outdoors por localização.
          As promoções ativas serão exibidas automaticamente no orçamento com o preço original riscado.
        </p>
      </div>

      <% if @promotions.any? %>
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Localização</th>
              <th>Tipo</th>
              <th>Preço Original</th>
              <th>Preço Promocional</th>
              <th>Desconto</th>
              <th>Período</th>
              <th>Status</th>
              <th>Criado por</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% @promotions.each do |promotion| %>
              <tr class="<%= 'admin-row-inactive' unless promotion.active %>">
                <td><strong>#<%= promotion.id %></strong></td>
                <td><%= promotion.outdoor_location_label %></td>
                <td>
                  <span class="admin-badge admin-badge-<%= promotion.promotion_type == 'monthly' ? 'info' : 'warning' %>">
                    <%= promotion.promotion_type_label %>
                  </span>
                </td>
                <td style="text-decoration: line-through; color: #999;">
                  R$ <%= number_with_delimiter(promotion.original_price.to_i, delimiter: '.') %>,00
                </td>
                <td style="color: #28a745; font-weight: bold;">
                  R$ <%= number_with_delimiter(promotion.promotional_price.to_i, delimiter: '.') %>,00
                </td>
                <td>
                  <span class="admin-badge admin-badge-success">
                    -<%= promotion.discount_percentage %>%
                  </span>
                </td>
                <td>
                  <% if promotion.start_date && promotion.end_date %>
                    <%= promotion.start_date.strftime('%d/%m/%Y') %> - <%= promotion.end_date.strftime('%d/%m/%Y') %>
                  <% elsif promotion.start_date %>
                    A partir de <%= promotion.start_date.strftime('%d/%m/%Y') %>
                  <% else %>
                    Permanente
                  <% end %>
                </td>
                <td>
                  <% if promotion.active && promotion.active_now? %>
                    <span class="admin-badge admin-badge-success">Ativa</span>
                  <% elsif promotion.active %>
                    <span class="admin-badge admin-badge-warning">Agendada</span>
                  <% else %>
                    <span class="admin-badge admin-badge-secondary">Inativa</span>
                  <% end %>
                </td>
                <td><%= promotion.admin_user&.email || 'Sistema' %></td>
                <td>
                  <%= link_to 'Editar', edit_admin_promotion_path(promotion), class: 'admin-btn-sm admin-btn-primary' %>
                  <%= button_to promotion.active? ? 'Desativar' : 'Ativar',
                      toggle_active_admin_promotion_path(promotion),
                      method: :patch,
                      class: "admin-btn-sm #{promotion.active? ? 'admin-btn-warning' : 'admin-btn-success'}" %>
                  <%= button_to 'Remover', admin_promotion_path(promotion),
                      method: :delete,
                      data: { confirm: 'Tem certeza que deseja remover esta promoção?' },
                      class: 'admin-btn-sm admin-btn-danger' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="admin-empty-state">
          <i class="fas fa-tags"></i>
          <p>Nenhuma promoção cadastrada</p>
          <%= link_to 'Criar Primeira Promoção', new_admin_promotion_path, class: 'admin-btn-success' %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<style>
.admin-row-inactive {
  opacity: 0.6;
}
</style>

