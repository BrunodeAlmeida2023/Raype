<!DOCTYPE html>
<html>
  <head>
    <title>Raype Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" type="image/png" href="/Logo.png">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="admin-body">
    <!-- Admin Header -->
    <header class="admin-header">
      <div class="admin-header-left">
        <div class="admin-logo">
          <img src="/Logo.png" alt="Raype Logo" class="admin-logo-img">
          <h1>RAYPE <span class="admin-badge">ADMIN</span></h1>
        </div>
      </div>
      <nav class="admin-nav">
        <%= link_to admin_dashboard_path, class: "admin-nav-link #{'active' if current_page?(admin_dashboard_path)}" do %>
          <i class="fas fa-dashboard"></i> Dashboard
        <% end %>
        <%= link_to admin_outdoors_path, class: "admin-nav-link #{'active' if controller_path.start_with?('admin/outdoors') || controller_path.start_with?('admin/blocked_dates')}" do %>
          <i class="fas fa-rectangle-ad"></i> Outdoors
        <% end %>
        <%= link_to admin_rents_path, class: "admin-nav-link #{'active' if controller_path.start_with?('admin/rents')}" do %>
          <i class="fas fa-file-invoice-dollar"></i> Aluguéis
        <% end %>
        <%= link_to admin_location_blocked_dates_path, class: "admin-nav-link #{'active' if controller_path.start_with?('admin/location_blocked_dates')}" do %>
          <i class="fas fa-map-marker-alt"></i> Bloqueios
        <% end %>
        <%= link_to root_path, class: "admin-nav-link" do %>
          <i class="fas fa-home"></i> Site
        <% end %>
        <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "admin-nav-link" do %>
          <i class="fas fa-sign-out-alt"></i> Sair
        <% end %>
      </nav>
      <div class="admin-user-info">
        <i class="fas fa-user-shield"></i>
        <%= current_user.email %>
      </div>
    </header>

    <!-- Breadcrumb -->
    <% if @breadcrumbs.present? %>
      <div class="admin-breadcrumb">
        <% @breadcrumbs.each_with_index do |crumb, index| %>
          <% if index > 0 %>
            <i class="fas fa-chevron-right"></i>
          <% end %>
          <% if crumb[:path] %>
            <%= link_to crumb[:name], crumb[:path] %>
          <% else %>
            <span><%= crumb[:name] %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <!-- Flash Messages -->
    <% if flash[:notice] %>
      <div class="admin-flash admin-flash-success">
        <i class="fas fa-check-circle"></i>
        <%= flash[:notice] %>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="admin-flash admin-flash-error">
        <i class="fas fa-exclamation-circle"></i>
        <%= flash[:alert] %>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="admin-content">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="admin-footer">
      <p>&copy; 2026 Raype. Todos os direitos reservados. | Área Administrativa</p>
    </footer>
  </body>
</html>




