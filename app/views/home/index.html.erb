<div class="content-wrap">
  <header class="home-header">
    <div class="home-header-left">
      <div class="home-header-logo">
        <img src="/Logo.png" alt="Raype Logo" class="header-logo-img">
      </div>
      <h1>RAYPE</h1>
    </div>
    <nav class="home-nav">
      <span class="home-nav-btn home-nav-user">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="user-icon">
          <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM3.751 20.105a8.25 8.25 0 0 1 16.498 0 .75.75 0 0 1-.437.695A18.683 18.683 0 0 1 12 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 0 1-.437-.695Z" clip-rule="evenodd"/>
        </svg>
        <%= current_user.email %>
        <% if current_user.admin? %>
          <span class="home-user-badge">ADMIN</span>
        <% end %>
      </span>
      <a href="#" class="home-nav-btn">Ajuda</a>
      <a href="#contact-section" class="home-nav-btn" id="contact-button">Contato</a>
      <a href="#services-section" class="home-nav-btn">Orçamentos</a>
      <% if current_user.admin? %>
        <a href="/sidekiq" target="_blank" class="home-nav-btn">Sidekiq</a>
        <a href="/flipper" target="_blank" class="home-nav-btn">Flipper</a>
      <% end %>
      <%= link_to "Sair", destroy_user_session_path, data: { turbo_method: :delete }, class: "home-nav-btn btn-logout" %>
    </nav>
  </header>

  <div class="home-banner">
    <div class="home-banner-carousel" id="carousel-container">
      <div class="home-banner-slide" id="home-slide-1">
        <h1>SLIDE 1: OUTDOOR TRIEDO</h1>
      </div>

      <div class="home-banner-slide" id="home-slide-2">
        <h1>SLIDE 2: OUTDOOR TRIEDO</h1>
      </div>

      <div class="home-banner-slide" id="home-slide-3">
        <h1>SLIDE 3: NOVIDADE LED</h1>
      </div>
    </div>
  </div>

  <section class="home-description">
    <h1 class="home-description-title">Bem Vindo à Raype!</h1>
    <p class="home-description-text">
      Na Raype, atuamos com marketing de outdoors Triedo e Led, onde amparamos sua marca com marketing visual e digital,
      nosso grande foco está em projeto de campanhas com o melhor custo benefício do mercado, tanto no digital ou
      visual<!doctype html>
      <html lang="en">
      <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
        <meta http-equiv="X-UA-Compatible" content="ie=edge">
        <title>Document</title>
      </head>
      <body>

      </body>
      </html>
    </p>
  </section>

  <section class="home-services" id="services-section">
    <h1 class="home-services-title">Orçamentos</h1>

    <%
      # ✅ Usa helpers para lógica limpa
      outdoor_completed = outdoor_completed?(@outdoor)
      date_completed = date_completed?(@outdoor)
      art_completed = art_completed?(@outdoor)
      all_completed = all_steps_completed?(@outdoor)

      block_changes = user_has_blocking_rent?(current_user)
      has_pending_rent = user_pending_rent(current_user).present?
      has_paid_rent = user_paid_rent(current_user).present?
    %>

    <div class="home-services-grid">
      <div class="home-service-card <%= 'card-blocked' if block_changes %>">
        <% if outdoor_completed %>
          <div class="home-service-icon home-service-check">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="56" height="56">
              <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd"/>
            </svg>
          </div>
        <% else %>
          <i class="home-service-icon fas fa-map-location-dot"></i>
        <% end %>
        <div class="home-service-description">
          <% if outdoor_completed %>
            <span class="service-completed-text">Outdoor Selecionado</span>
          <% else %>
            Qual outdoor?
          <% end %>
        </div>
        <% if block_changes %>
          <button class="home-service-btn btn-blocked #{'btn-alterar' if outdoor_completed}" disabled title="<%= finalize_button_tooltip(has_paid_rent, has_pending_rent) %>">
            <%= outdoor_completed ? "Alterar" : "Escolher" %>
            <i class="fas fa-lock"></i>
          </button>
        <% else %>
          <%= link_to outdoor_completed ? "Alterar" : "Escolher", find_outdoor_home_path, class: "home-service-btn #{'btn-alterar' if outdoor_completed}" %>
        <% end %>
      </div>

      <div class="home-service-card <%= 'card-blocked' if block_changes %>">
        <% if date_completed %>
          <div class="home-service-icon home-service-check">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="56" height="56">
              <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd"/>
            </svg>
          </div>
        <% else %>
          <i class="home-service-icon fas fa-calendar-alt"></i>
        <% end %>
        <div class="home-service-description">
          <% if date_completed %>
            <span class="service-completed-text">Data Selecionada</span>
          <% else %>
            Qual Data?
          <% end %>
        </div>
        <% if block_changes %>
          <button class="home-service-btn btn-blocked #{'btn-alterar' if date_completed}" disabled title="<%= finalize_button_tooltip(has_paid_rent, has_pending_rent) %>">
            <%= date_completed ? "Alterar" : "Escolher" %>
            <i class="fas fa-lock"></i>
          </button>
        <% else %>
          <%= link_to date_completed ? "Alterar" : "Escolher", find_date_home_path, class: "home-service-btn #{'btn-alterar' if date_completed}" %>
        <% end %>
      </div>

      <div class="home-service-card <%= 'card-blocked' if block_changes %>">
        <% if art_completed %>
          <div class="home-service-icon home-service-check">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="56" height="56">
              <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd"/>
            </svg>
          </div>
        <% else %>
          <i class="home-service-icon fas fa-signs-post"></i>
        <% end %>
        <div class="home-service-description">
          <% if art_completed %>
            <span class="service-completed-text">Arte Enviada</span>
          <% else %>
            Escolha sua Arte?
          <% end %>
        </div>
        <% if block_changes %>
          <button class="home-service-btn btn-blocked #{'btn-alterar' if art_completed}" disabled title="<%= finalize_button_tooltip(has_paid_rent, has_pending_rent) %>">
            <%= art_completed ? "Alterar" : "Escolher" %>
            <i class="fas fa-lock"></i>
          </button>
        <% else %>
          <%= link_to art_completed ? "Alterar" : "Escolher", choose_art_home_path, class: "home-service-btn #{'btn-alterar' if art_completed}" %>
        <% end %>
      </div>
    </div>

    <div style="text-align: center; width: 100%;">
      <%
        # Verifica rents usando helpers já definidos
        paid_rent = user_paid_rent(current_user)
        pending_rent = user_pending_rent(current_user)
      %>

      <% if paid_rent.present? %>
        <!-- Usuário tem pedido PAGO - Mostrar botão de WhatsApp -->
        <%= link_to pedido_whatsapp_link(paid_rent), class: "home-finalize-budget-btn home-whatsapp-btn", target: "_blank", data: { turbo: false } do %>
          <i class="fab fa-whatsapp"></i>
          Entrar em Contato - Enviar Informações
        <% end %>
      <% elsif pending_rent.present? %>
        <!-- Usuário tem pedido PENDENTE - Mostrar status -->
        <%= link_to order_status_path(pending_rent.id), class: "home-finalize-budget-btn home-status-btn", data: { turbo: false } do %>
          <i class="fas fa-clipboard-list"></i>
          Verificar Status do Pedido
        <% end %>
      <% elsif all_completed %>
        <!-- Sem pedidos - Permitir criar novo orçamento -->
        <%= link_to finalize_budget_home_path, class: "home-finalize-budget-btn", data: { turbo: false } do %>
          <i class="fas fa-check-circle"></i>
          Finalizar Orçamento
        <% end %>
      <% else %>
        <!-- Etapas incompletas -->
        <button class="home-finalize-budget-btn disabled" disabled>
          <i class="fas fa-lock"></i>
          Finalizar Orçamento
        </button>
      <% end %>
    </div>
  </section>
</div>

