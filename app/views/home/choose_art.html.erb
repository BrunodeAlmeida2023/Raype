<% content_for :body_class, "orange-bg" %>

<header class="home-header">
  <div class="home-header-left">
    <div class="home-header-logo">
      <img src="/Logo.png" alt="Raype Logo" class="header-logo-img">
    </div>
    <h1>RAYPE</h1>
  </div>
  <nav class="home-nav">
    <%= link_to "Voltar", root_path, class: "home-nav-btn" %>
  </nav>
</header>

<div class="content-wrap">
  <section class="home-services">
    <h1 class="home-services-title">Escolha sua Arte</h1>

    <%# Dados para o JavaScript %>
    <div id="choose-art-data"
         data-has-own-art="<%= @outdoor&.has_own_art.nil? ? '' : @outdoor.has_own_art.to_s %>"
         data-selected-faces="<%= (@outdoor&.selected_faces || []).to_json %>"
         data-saved-arts="<%= saved_art_urls(@outdoor).to_json %>"
         class="hidden-data">
    </div>

    <%= form_with url: post_choose_art_home_path, method: :post, multipart: true, class: "home-form-container choose-art-form", id: "choose-art-form", data: { turbo: false } do |f| %>
      <div class="choose-art-layout">
        <div class="choose-art-left">

          <!-- Primeira Pergunta: Tem arte pronta? -->
          <div class="home-form-group art-ownership-group">
            <%= f.label :has_own_art, "Você contém artes prontas?", class: "home-form-label art-ownership-label" %>
            <%= f.select :has_own_art,
                [
                  ['Selecione uma opção', ''],
                  ['Sim, eu tenho artes prontas', 'true'],
                  ['Não tenho arte, preciso que criem para mim', 'false']
                ],
                { selected: choose_art_ownership_value(@outdoor) },
                { class: "home-form-select art-ownership-select", id: "has_own_art", required: true }
            %>
          </div>

          <!-- Segunda Pergunta: Quantas faces? -->
          <div class="home-form-group faces-selection-group" id="faces-selection-group" style="display: none;">
            <%= f.label :selected_faces, "Quantas faces do outdoor você deseja alugar?", class: "home-form-label faces-selection-label" %>
            <p class="home-form-hint">Selecione uma ou mais faces do outdoor clicando nas opções abaixo</p>

            <div class="faces-checkboxes" id="faces-checkboxes">
              <label class="face-checkbox-label">
                <%= check_box_tag 'selected_faces[]', 1, face_selected?(@outdoor, 1), id: 'face_1', class: 'face-checkbox' %>
                <span class="face-label-text">Face 1</span>
              </label>

              <label class="face-checkbox-label">
                <%= check_box_tag 'selected_faces[]', 2, face_selected?(@outdoor, 2), id: 'face_2', class: 'face-checkbox' %>
                <span class="face-label-text">Face 2</span>
              </label>

              <label class="face-checkbox-label">
                <%= check_box_tag 'selected_faces[]', 3, face_selected?(@outdoor, 3), id: 'face_3', class: 'face-checkbox' %>
                <span class="face-label-text">Face 3</span>
              </label>
            </div>

            <p class="faces-hint" id="faces-count-hint"></p>
          </div>

          <!-- Container para upload de arquivos (quando tem arte própria) -->
          <div id="upload-fields-container" class="upload-fields-grid" style="display: none;">
            <!-- Campos de upload serão inseridos dinamicamente via JS -->
          </div>

          <!-- Mensagem quando não tem arte própria -->
          <div id="no-art-message" class="no-art-message" style="display: none;">
            <p>✨ Não se preocupe! Nossa equipe criará artes incríveis para você.</p>
          </div>
        </div>

        <div class="choose-art-right">
          <!-- Preview do Outdoor Triedo -->
          <div id="outdoor-preview-container" class="outdoor-preview-container" style="display: none;">
            <h3 class="preview-title">Prévia do seu Outdoor</h3>
            <div class="triedo-wrapper">
              <div id="triedo-display" class="triedo-display">
                <div class="triedo-placeholder">
                  <p>Faça upload das suas artes para visualizar</p>
                </div>
              </div>
              <div class="triedo-structure">
                <div class="triedo-pole"></div>
                <div class="triedo-base"></div>
              </div>
            </div>
            <p class="preview-hint">* As imagens rotacionam automaticamente simulando um outdoor triedo</p>
          </div>
        </div>

        <div class="home-form-actions choose-art-actions">
          <%= f.submit "Continuar",
              class: "home-submit-btn",
              id: "submit-choose-art",
              type: "submit",
              data: { disable_with: "⏳ Processando..." } %>
          <div class="loading-spinner" id="loading-spinner" style="display: none;">
            <div class="spinner"></div>
            <p>Processando suas artes... Por favor, aguarde.</p>
          </div>
        </div>
      </div>
    <% end %>
  </section>
</div>



